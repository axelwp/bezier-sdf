{
  "name": "bezier-sdf-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Render SVG vectors as GPU signed-distance fields computed directly from cubic Bezier curves.",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "dev:examples": "pnpm -r --filter './examples/*' run dev"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
